# ============================================================
# .env.example
# ============================================================
# Copia este archivo como ".env" (sin .example) para desarrollo
# LOCAL en tu computadora. En Render, estas variables se
# configuran desde el dashboard, NO subas el archivo .env real
# a GitHub (agrégalo a tu .gitignore).
# ============================================================

# Render te da esta URL automáticamente cuando creas la base de
# datos Postgres y la conectas a tu Web Service. Para probar en
# tu compu, usa la "External Database URL" que te muestra Render
# en el dashboard de tu base de datos.
DATABASE_URL=postgresql://usuario:password@host:5432/nombre_basedatos

# Una clave secreta larga y aleatoria, usada para firmar las
# cookies de sesión. Genera una con: openssl rand -hex 32
SESSION_SECRET=cambia_esto_por_una_clave_larga_y_aleatoria

# Puerto en el que corre el servidor. Render asigna el suyo
# automáticamente vía process.env.PORT, esta variable es solo
# para cuando lo corres en tu propia compu.
PORT=3000
